{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/openai-cred-gate.py\"",
            "shell": "bash"
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/gemini-cred-gate.py\"",
            "shell": "bash"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "unreal-skills@unreal-harness": true
  },
  "extraKnownMarketplaces": {
    "unreal-harness": {
      "source": {
        "source": "directory",
        "path": "."
      }
    }
  }
}
